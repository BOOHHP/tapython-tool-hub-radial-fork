# tapython-tool-hub — Local Deployment

# ── API Server ──────────────────────────────────────
# PostgreSQL connection (optional; falls back to file storage when empty)
# DATABASE_URL=postgresql://user:password@localhost:5432/tapython_tool_hub

# API listen host (default: 127.0.0.1; set to 0.0.0.0 for LAN access)
API_HOST=127.0.0.1

# API listen port
API_PORT=8787

# ── Admin Login ───────────────────────────────────
# Required before /api/admin/* can be used.
ADMIN_USERNAME=admin

# Generate with:
# node -e "const crypto=require('node:crypto'); const p=process.argv[1]; const s=crypto.randomBytes(16).toString('base64url'); const i=210000; const h=crypto.pbkdf2Sync(p,s,i,32,'sha256').toString('base64url'); console.log(`pbkdf2-sha256$${i}$${s}$${h}`)" "your-password"
ADMIN_PASSWORD_HASH=

# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
AUTH_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=12

# ── Web Frontend (build-time) ──────────────────────
# Override API base URL for the built web app.
# Leave empty or set to auto to resolve from the browser hostname:
# - localhost/127.* -> http://127.0.0.1:8787
# - server IP       -> http://<server-ip>:8787 on dev/preview ports
# VITE_API_BASE_URL=auto

# ── Data Paths (rarely needed) ─────────────────────
# TOOL_DATA_ROOT=<repo>/data/tools
# TOOL_DOCS_ROOT=<repo>/data/tool-docs
# TOOL_API_ROOT=<repo>/apps/web/public/api/tools
# TOOL_DOWNLOAD_ROOT=<repo>/apps/web/public/downloads
# SUBMISSION_ROOT=<repo>/.tapython-tool-hub/submissions
